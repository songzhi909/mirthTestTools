      {"label": "检查申请号", "xpath": "ListInfo/ListRow/EXAM_ITEMS/PriKeyList/EXAM_NO"},
      {"label": "检查项目序号", "xpath": "ListInfo/ListRow/EXAM_ITEMS/PriKeyList/EXAM_ITEM_NO"},
      {"label": "检查类别", "xpath": "ListInfo/ListRow/EXAM_APPOINTS/PriKeyList/EXAM_CLASS"}
    ],
    "channels": [
