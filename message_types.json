{
  "检查申请新增": {
    "code": "TJ001",
    "flow": {
      "sequential": true,
      "stop_on_empty": true
    },
    "query_fields": [
      {
        "label": "检查申请号",
        "xml_tag": "EXAM_NO",
        "required": true
      }
    ],
    "extract_fields": [
      {"label": "事件类型", "xpath": "EventType"},
